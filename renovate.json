{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "kubernetes": {
    "managerFilePatterns": [
      "/\\.yaml$/"
    ]
  },
  "kustomize": {
    "managerFilePatterns": [
      "/(^|/)kustomization\\.yaml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/apps/.+/values\\.yaml$/",
      "/core/.+/values\\.yaml$/"
    ]
  },
  "argocd": {
    "managerFilePatterns": [
      "/apps/.+\\.yaml$/",
      "/core/.+\\.yaml$/",
      "/github-action-runner/.+\\.yaml$/",
      "/cronjobs/.+\\.yaml$/"
    ]
  },
  "packageRules": [
    {
      "matchPackageNames": [
        "argo-cd"
      ],
      "groupName": "ArgoCD",
      "automerge": false
    },
    {
      "groupName": "Infrastructure Charts",
      "automerge": false,
      "matchPackageNames": [
        "/^traefik/",
        "/^cert-manager/",
        "/^external-secrets/"
      ]
    },
    {
      "groupName": "Monitoring Stack",
      "automerge": false,
      "matchPackageNames": [
        "/^kube-prometheus/",
        "/^prometheus/",
        "/^grafana/"
      ]
    },
    {
      "matchPackageNames": [
        "longhorn"
      ],
      "groupName": "Longhorn",
      "automerge": false
    },
    {
      "matchPackageNames": [
        "flannel-io/flannel"
      ],
      "groupName": "Flannel",
      "automerge": false
    }
  ]
}
