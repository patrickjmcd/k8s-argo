{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "kubernetes": {
    "managerFilePatterns": [
      "/\\.yaml$/"
    ]
  },
  "kustomize": {
    "managerFilePatterns": [
      "/(^|/)kustomization\\.yaml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/apps/.+/values\\.yaml$/",
      "/core/.+/values\\.yaml$/"
    ]
  },
  "argocd": {
    "managerFilePatterns": [
      "/apps/.+\\.yaml$/",
      "/core/.+\\.yaml$/",
      "/github-action-runner/.+\\.yaml$/",
      "/cronjobs/.+\\.yaml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^apps/immich/values\\.yaml$/"],
      "matchStrings": [
        "# renovate: depName=(?<depName>.*?)\\s*\\n\\s*tag: (?<currentValue>.*)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^core/system-upgrade/(agent|server)-plan\\.yaml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s*\\n\\s*version: (?<currentValue>\\S+)"
      ],
      "versioningTemplate": "regex:^v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\+k3s(?<build>\\d+)$"
    }
  ],
  "ignoreDeps": [
    "ghcr.io/patrickjmcd/lake-info"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "ArgoCD native OCI sources use repoURL as the full chart path, but Renovate's argocd manager appends the chart name â€” strip the duplicate segment",
      "matchPackageNames": [
        "ghcr.io/containers/charts/kubernetes-mcp-server/kubernetes-mcp-server"
      ],
      "overridePackageName": "ghcr.io/containers/charts/kubernetes-mcp-server"
    },
    {
      "matchPackageNames": [
        "argo-cd"
      ],
      "groupName": "ArgoCD",
      "automerge": false
    },
    {
      "groupName": "Infrastructure Charts",
      "automerge": false,
      "matchPackageNames": [
        "/^traefik/",
        "/^cert-manager/",
        "/^external-secrets/"
      ]
    },
    {
      "groupName": "Monitoring Stack",
      "automerge": false,
      "matchPackageNames": [
        "/^kube-prometheus/",
        "/^prometheus/",
        "/^grafana/"
      ]
    },
    {
      "matchPackageNames": [
        "longhorn"
      ],
      "groupName": "Longhorn",
      "automerge": false
    },
    {
      "matchPackageNames": [
        "flannel-io/flannel"
      ],
      "groupName": "Flannel",
      "automerge": false
    },
    {
      "matchDepNames": [
        "k3s-io/k3s"
      ],
      "groupName": "k3s",
      "automerge": false,
      "prBodyNotes": [
        "Merging starts the node upgrade rollout immediately (ArgoCD auto-sync). Servers upgrade first, then agents, one node at a time. Never merge a minor-version jump larger than one; check no Proxmox host maintenance is in progress."
      ]
    }
  ]
}
